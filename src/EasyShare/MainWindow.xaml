<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="EasyShare.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:EasyShare"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:resources="using:EasyShare.Resources"
    Title="EasyShare"
    mc:Ignorable="d">

    <Grid>
        <Grid.Resources>
            <resources:TextProvider x:Key="Text" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            MinHeight="36"
            Padding="12,0"
            Background="Transparent"
            ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Image
                Width="16"
                Height="16"
                VerticalAlignment="Center"
                Source="Assets/LogoIcon.png" />
            <TextBlock
                x:Name="AppTitleText"
                Grid.Column="1"
                VerticalAlignment="Center"
                Text="{Binding Source={StaticResource Text}, Path=AppName}" />
        </Grid>

        <Frame
            x:Name="RootFrame"
            Grid.Row="1"
            Background="Transparent" />
    </Grid>
</Window>
