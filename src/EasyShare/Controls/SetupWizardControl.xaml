<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="EasyShare.Controls.SetupWizardControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    IsTabStop="True"
    Loaded="Root_Loaded"
    Unloaded="Root_Unloaded"
    KeyDown="Root_KeyDown"
    SizeChanged="Root_SizeChanged">

    <UserControl.Resources>
        <Style x:Key="WizardRailButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="{StaticResource EasyShareControlCornerRadius}" />
        </Style>
        <Style x:Key="WizardSectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="WizardHelpTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Grid x:Name="OverlayRoot"
          Background="{ThemeResource EasyShareOverlayBackgroundBrush}"
          TabFocusNavigation="Cycle">
        <Grid x:Name="ShellGrid"
              MaxWidth="1280"
              Margin="36,24,36,28"
              HorizontalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="HeaderGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Width="48"
                        Height="48"
                        Margin="0,0,14,0"
                        Background="{ThemeResource EasyShareAccentSoftBrush}"
                        CornerRadius="{StaticResource EasyShareIconCornerRadius}">
                    <Image Source="/Assets/LogoIcon.png"
                           Width="32"
                           Height="32"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="WizardTitleText"
                               FontSize="24"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="WizardSubtitleText"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border x:Name="ManagedBadge"
                        Grid.Column="2"
                        Margin="16,0,0,0"
                        Padding="10,6"
                        VerticalAlignment="Center"
                        Background="{ThemeResource EasyShareAccentSoftBrush}"
                        CornerRadius="{StaticResource EasyShareControlCornerRadius}"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <FontIcon Glyph="&#xE72E;" FontSize="13" />
                        <TextBlock x:Name="ManagedBadgeText"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel x:Name="CompactProgressPanel"
                            Grid.Row="1"
                            Grid.ColumnSpan="3"
                            Margin="0,16,0,0"
                            Spacing="6"
                            Visibility="Collapsed">
                    <TextBlock x:Name="CompactProgressText"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ProgressBar x:Name="CompactProgressBar"
                                 Minimum="0"
                                 Maximum="7"
                                 Height="4" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,22,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="StepRailColumn" Width="288" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="StepRail"
                        Grid.Column="0"
                        Margin="0,0,18,0"
                        Padding="12"
                        Background="{ThemeResource EasyShareSurfaceBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource EasyShareCardCornerRadius}">
                    <StackPanel Spacing="4">
                        <Button x:Name="WelcomeRailButton"
                                Tag="0"
                                Click="RailStep_Click"
                                Style="{StaticResource WizardRailButtonStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="WelcomeRailMarker" Width="32" Height="32" CornerRadius="16"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}">
                                    <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="WelcomeRailTitle" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock x:Name="WelcomeRailDescription" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" MaxLines="2" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="AppearanceRailButton" Tag="1" Click="RailStep_Click"
                                Style="{StaticResource WizardRailButtonStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border x:Name="AppearanceRailMarker" Width="32" Height="32" CornerRadius="16"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}">
                                    <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="AppearanceRailTitle" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock x:Name="AppearanceRailDescription" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" MaxLines="2" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="AccessRailButton" Tag="2" Click="RailStep_Click"
                                Style="{StaticResource WizardRailButtonStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border x:Name="AccessRailMarker" Width="32" Height="32" CornerRadius="16"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}">
                                    <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="AccessRailTitle" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock x:Name="AccessRailDescription" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" MaxLines="2" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="ConnectionRailButton" Tag="3" Click="RailStep_Click"
                                Style="{StaticResource WizardRailButtonStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border x:Name="ConnectionRailMarker" Width="32" Height="32" CornerRadius="16"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}">
                                    <TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="ConnectionRailTitle" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock x:Name="ConnectionRailDescription" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" MaxLines="2" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="WindowsRailButton" Tag="4" Click="RailStep_Click"
                                Style="{StaticResource WizardRailButtonStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border x:Name="WindowsRailMarker" Width="32" Height="32" CornerRadius="16"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}">
                                    <TextBlock Text="5" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="WindowsRailTitle" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock x:Name="WindowsRailDescription" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" MaxLines="2" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="OfflineRailButton" Tag="5" Click="RailStep_Click"
                                Style="{StaticResource WizardRailButtonStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border x:Name="OfflineRailMarker" Width="32" Height="32" CornerRadius="16"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}">
                                    <TextBlock Text="6" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="OfflineRailTitle" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock x:Name="OfflineRailDescription" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" MaxLines="2" />
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="ReviewRailButton" Tag="6" Click="RailStep_Click"
                                Style="{StaticResource WizardRailButtonStyle}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="34" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Border x:Name="ReviewRailMarker" Width="32" Height="32" CornerRadius="16"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}">
                                    <TextBlock Text="7" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock x:Name="ReviewRailTitle" FontWeight="SemiBold" TextWrapping="Wrap" />
                                    <TextBlock x:Name="ReviewRailDescription" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap" MaxLines="2" />
                                </StackPanel>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="1"
                        Background="{ThemeResource EasyShareSurfaceBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource EasyShareCardCornerRadius}">
                    <ScrollViewer x:Name="ContentScrollViewer"
                                  Padding="30,26,30,30"
                                  HorizontalScrollMode="Disabled"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollMode="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ContentStack" MaxWidth="760" HorizontalAlignment="Stretch" Spacing="20">
                            <InfoBar x:Name="ValidationInfoBar"
                                     IsOpen="False"
                                     IsClosable="True"
                                     Severity="Error" />

                            <StackPanel Spacing="5">
                                <TextBlock x:Name="CurrentStepTitleText"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock x:Name="CurrentStepDescriptionText"
                                           FontSize="15"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <StackPanel x:Name="WelcomePanel" Spacing="20">
                                <TextBlock x:Name="WelcomeLeadText"
                                           FontSize="17"
                                           TextWrapping="Wrap" />
                                <StackPanel Spacing="7">
                                    <TextBlock x:Name="LanguageLabelText" Style="{StaticResource WizardSectionTitleStyle}" />
                                    <TextBlock x:Name="LanguageHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                                    <ComboBox x:Name="LanguageComboBox"
                                              MinWidth="280"
                                              MaxWidth="440"
                                              HorizontalAlignment="Left"
                                              SelectionChanged="LanguageComboBox_SelectionChanged">
                                        <ComboBoxItem x:Name="PortugueseLanguageItem" Tag="pt-BR" />
                                        <ComboBoxItem x:Name="EnglishLanguageItem" Tag="en-US" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="40" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE897;" FontSize="20" Foreground="{ThemeResource EasyShareAccentBrush}" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="GuidedBenefitTitleText" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock x:Name="GuidedBenefitMessageText" Style="{StaticResource WizardHelpTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="40" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE72E;" FontSize="20" Foreground="{ThemeResource EasyShareAccentBrush}" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="SecureBenefitTitleText" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock x:Name="SecureBenefitMessageText" Style="{StaticResource WizardHelpTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="40" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE713;" FontSize="20" Foreground="{ThemeResource EasyShareAccentBrush}" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock x:Name="FlexibleBenefitTitleText" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock x:Name="FlexibleBenefitMessageText" Style="{StaticResource WizardHelpTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="AppearancePanel" Spacing="20" Visibility="Collapsed">
                                <TextBlock x:Name="AppearanceLeadText" FontSize="17" TextWrapping="Wrap" />
                                <StackPanel Spacing="7">
                                    <TextBlock x:Name="ThemeLabelText" Style="{StaticResource WizardSectionTitleStyle}" />
                                    <ComboBox x:Name="ThemeComboBox"
                                              MinWidth="280"
                                              MaxWidth="440"
                                              HorizontalAlignment="Left"
                                              SelectionChanged="AppearanceControl_Changed">
                                        <ComboBoxItem x:Name="SystemThemeItem" Tag="System" />
                                        <ComboBoxItem x:Name="LightThemeItem" Tag="Light" />
                                        <ComboBoxItem x:Name="DarkThemeItem" Tag="Dark" />
                                    </ComboBox>
                                </StackPanel>
                                <ToggleSwitch x:Name="HighContrastToggle"
                                              Toggled="AppearanceControl_Changed" />
                                <Border Padding="18"
                                        Background="{ThemeResource EasyShareAccentSoftBrush}"
                                        CornerRadius="{StaticResource EasyShareInnerCornerRadius}">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="42" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE771;" FontSize="24" Foreground="{ThemeResource EasyShareAccentBrush}" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock x:Name="AppearancePreviewTitleText" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock x:Name="AppearancePreviewMessageText" Style="{StaticResource WizardHelpTextStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="AccessPanel" Spacing="16" Visibility="Collapsed">
                                <InfoBar x:Name="RecommendationInfoBar" IsOpen="True" Severity="Informational" IsClosable="False" />
                                <InfoBar x:Name="ManagedInfoBar" IsOpen="False" Severity="Informational" IsClosable="False" />

                                <Border Padding="16"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}"
                                        CornerRadius="{StaticResource EasyShareInnerCornerRadius}">
                                    <RadioButton x:Name="GraphAccessRadio"
                                                 GroupName="WizardAccessMode"
                                                 Checked="AccessMode_Changed">
                                        <StackPanel MaxWidth="620">
                                            <TextBlock x:Name="GraphAccessTitleText" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock x:Name="GraphAccessDescriptionText" Style="{StaticResource WizardHelpTextStyle}" />
                                        </StackPanel>
                                    </RadioButton>
                                </Border>

                                <Border Padding="16"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}"
                                        CornerRadius="{StaticResource EasyShareInnerCornerRadius}">
                                    <RadioButton x:Name="BrowserAccessRadio"
                                                 GroupName="WizardAccessMode"
                                                 Checked="AccessMode_Changed">
                                        <StackPanel MaxWidth="620">
                                            <TextBlock x:Name="BrowserAccessTitleText" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock x:Name="BrowserAccessDescriptionText" Style="{StaticResource WizardHelpTextStyle}" />
                                        </StackPanel>
                                    </RadioButton>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="ConnectionPanel" Spacing="18" Visibility="Collapsed">
                                <StackPanel x:Name="GraphConnectionPanel" Spacing="16">
                                    <TextBlock x:Name="GraphConnectionIntroText" FontSize="17" TextWrapping="Wrap" />
                                    <StackPanel Spacing="6">
                                        <TextBlock x:Name="ClientIdLabelText" FontWeight="SemiBold" />
                                        <TextBox x:Name="ClientIdTextBox"
                                                 MaxLength="64"
                                                 TextChanged="DraftTextBox_TextChanged" />
                                    </StackPanel>
                                    <StackPanel Spacing="6">
                                        <TextBlock x:Name="TenantLabelText" FontWeight="SemiBold" />
                                        <TextBox x:Name="TenantTextBox"
                                                 MaxLength="253"
                                                 TextChanged="DraftTextBox_TextChanged" />
                                    </StackPanel>
                                    <InfoBar x:Name="GraphSecurityInfoBar" IsOpen="True" IsClosable="False" Severity="Informational" />
                                </StackPanel>

                                <StackPanel x:Name="BrowserConnectionPanel" Spacing="16" Visibility="Collapsed">
                                    <TextBlock x:Name="BrowserConnectionIntroText" FontSize="17" TextWrapping="Wrap" />
                                    <StackPanel Spacing="6">
                                        <TextBlock x:Name="BrowserUrlLabelText" FontWeight="SemiBold" />
                                        <TextBox x:Name="BrowserUrlTextBox"
                                                 MaxLength="2048"
                                                 TextChanged="DraftTextBox_TextChanged" />
                                        <TextBlock x:Name="BrowserUrlHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                                    </StackPanel>
                                    <ToggleSwitch x:Name="BrowserKeepAliveToggle" />
                                    <TextBlock x:Name="BrowserKeepAliveHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel x:Name="WindowsIntegrationPanel" Spacing="18" Visibility="Collapsed">
                                <TextBlock x:Name="WindowsLeadText" FontSize="17" TextWrapping="Wrap" />
                                <InfoBar x:Name="WinFspInfoBar" IsOpen="False" IsClosable="False" Severity="Warning" />
                                <ToggleSwitch x:Name="AutoDriveToggle" Toggled="WindowsControl_Changed" />
                                <TextBlock x:Name="AutoDriveHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                                <StackPanel Spacing="6">
                                    <TextBlock x:Name="MountPointLabelText" FontWeight="SemiBold" />
                                    <ComboBox x:Name="MountPointComboBox"
                                              MinWidth="160"
                                              MaxWidth="280"
                                              HorizontalAlignment="Left" />
                                    <TextBlock x:Name="MountPointHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                                </StackPanel>
                                <ToggleSwitch x:Name="StartWithWindowsToggle" Toggled="WindowsControl_Changed" />
                                <TextBlock x:Name="StartWithWindowsHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                                <ToggleSwitch x:Name="StartMinimizedToggle" />
                                <TextBlock x:Name="StartMinimizedHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                            </StackPanel>

                            <StackPanel x:Name="OfflineAndNotificationsPanel" Spacing="18" Visibility="Collapsed">
                                <TextBlock x:Name="OfflineLeadText" FontSize="17" TextWrapping="Wrap" />

                                <Grid x:Name="OfflineColumnsGrid" ColumnSpacing="16" RowSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border x:Name="CacheCard"
                                            Grid.Column="0"
                                            Padding="18"
                                            Background="{ThemeResource EasyShareSurfaceSubtleBrush}"
                                            CornerRadius="{StaticResource EasyShareInnerCornerRadius}">
                                        <StackPanel Spacing="10">
                                            <TextBlock x:Name="CacheTitleText" Style="{StaticResource WizardSectionTitleStyle}" />
                                            <TextBlock x:Name="CacheMinutesLabelText" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <NumberBox x:Name="CacheMinutesNumberBox"
                                                       Minimum="1"
                                                       Maximum="1440"
                                                       SmallChange="1"
                                                       LargeChange="15"
                                                       SpinButtonPlacementMode="Inline" />
                                            <TextBlock x:Name="CacheHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                                        </StackPanel>
                                    </Border>

                                    <Border x:Name="OfflineStorageCard"
                                            Grid.Column="1"
                                            Padding="18"
                                            Background="{ThemeResource EasyShareSurfaceSubtleBrush}"
                                            CornerRadius="{StaticResource EasyShareInnerCornerRadius}">
                                        <StackPanel Spacing="10">
                                            <TextBlock x:Name="OfflineStorageTitleText" Style="{StaticResource WizardSectionTitleStyle}" />
                                            <TextBlock x:Name="OfflineLimitLabelText" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <NumberBox x:Name="OfflineLimitNumberBox"
                                                       Minimum="128"
                                                       Maximum="102400"
                                                       SmallChange="128"
                                                       LargeChange="1024"
                                                       SpinButtonPlacementMode="Inline" />
                                            <TextBlock x:Name="OfflineLimitHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                                            <CheckBox x:Name="PauseMeteredCheckBox" />
                                            <CheckBox x:Name="PauseBatteryCheckBox" />
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <Border Padding="18"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}"
                                        CornerRadius="{StaticResource EasyShareInnerCornerRadius}">
                                    <StackPanel Spacing="10">
                                        <TextBlock x:Name="NotificationsTitleText" Style="{StaticResource WizardSectionTitleStyle}" />
                                        <ToggleSwitch x:Name="NotificationsToggle" Toggled="NotificationsControl_Changed" />
                                        <TextBlock x:Name="NotificationsHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                                        <ToggleSwitch x:Name="QuietModeToggle" />
                                        <TextBlock x:Name="QuietModeHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel x:Name="ReviewPanel" Spacing="18" Visibility="Collapsed">
                                <TextBlock x:Name="ReviewLeadText" FontSize="17" TextWrapping="Wrap" />
                                <Border Padding="20"
                                        Background="{ThemeResource EasyShareSurfaceSubtleBrush}"
                                        CornerRadius="{StaticResource EasyShareInnerCornerRadius}">
                                    <StackPanel Spacing="10">
                                        <TextBlock x:Name="ReviewConfigurationTitleText" Style="{StaticResource WizardSectionTitleStyle}" />
                                        <TextBlock x:Name="ReviewSummaryText"
                                                   TextWrapping="Wrap"
                                                   LineHeight="25" />
                                    </StackPanel>
                                </Border>
                                <InfoBar x:Name="ReviewSecurityInfoBar" IsOpen="True" IsClosable="False" Severity="Success" />
                                <ToggleSwitch x:Name="ConnectNowToggle" />
                                <TextBlock x:Name="ConnectNowHelpText" Style="{StaticResource WizardHelpTextStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid x:Name="FooterGrid" Grid.Row="2" ColumnSpacing="12" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="0" />
                </Grid.RowDefinitions>

                <Button x:Name="CancelButton" Click="CancelButton_Click" />

                <StackPanel x:Name="BusyPanel"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10"
                            Visibility="Collapsed">
                    <ProgressRing x:Name="BusyProgressRing" Width="20" Height="20" IsActive="False" />
                    <TextBlock x:Name="BusyText" VerticalAlignment="Center" />
                </StackPanel>

                <StackPanel x:Name="ActionButtonsPanel"
                            Grid.Column="2"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal"
                            Spacing="10">
                    <Button x:Name="BackButton" Click="BackButton_Click" />
                    <Button x:Name="NextButton" Click="NextButton_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="FinishButton" Click="FinishButton_Click" Style="{StaticResource AccentButtonStyle}" Visibility="Collapsed" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
