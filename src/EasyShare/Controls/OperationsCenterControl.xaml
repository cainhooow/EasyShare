<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="EasyShare.Controls.OperationsCenterControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:EasyShare.Models"
    xmlns:resources="using:EasyShare.Resources">
    <UserControl.Resources>
        <resources:TextProvider x:Key="Text" />
    </UserControl.Resources>

    <TabView
        x:Name="OperationsTabs"
        IsAddTabButtonVisible="False"
        TabCloseRequested="TabView_TabCloseRequested">
        <TabViewItem Header="{Binding Source={StaticResource Text}, Path=OperationsTransfersTab}" IsClosable="False">
            <Grid Padding="0,12,0,0">
                <ListView ItemsSource="{x:Bind ViewModel.Transfers, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SyncJob">
                            <Grid Padding="12,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="190" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3">
                                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind FileName}" />
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind RouteDisplayName}" />
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind UpdatedText}" />
                                    <TextBlock
                                        Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                        Text="{x:Bind LastError}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="6">
                                    <TextBlock Text="{x:Bind StateText}" />
                                    <ProgressBar Maximum="100" Value="{x:Bind Progress}" />
                                    <Button
                                        Click="RetryButton_Click"
                                        Content="{Binding Source={StaticResource Text}, Path=ActionRetryUpload}"
                                        Tag="{x:Bind Id}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </TabViewItem>

        <TabViewItem Header="{Binding Source={StaticResource Text}, Path=OperationsConflictsTab}" IsClosable="False">
            <Grid Padding="0,12,0,0">
                <ListView ItemsSource="{x:Bind ViewModel.Conflicts, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SyncJob">
                            <Grid Padding="12,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3">
                                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind FileName}" />
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind RouteDisplayName}" />
                                    <TextBlock Text="{x:Bind LastError}" TextWrapping="Wrap" />
                                </StackPanel>
                                <CommandBar
                                    Grid.Column="1"
                                    Background="Transparent"
                                    DefaultLabelPosition="Collapsed"
                                    IsDynamicOverflowEnabled="True">
                                    <AppBarButton
                                        Click="ExportConflictButton_Click"
                                        Label="{Binding Source={StaticResource Text}, Path=ActionSaveLocalCopy}"
                                        Tag="{x:Bind Id}">
                                        <AppBarButton.Icon><SymbolIcon Symbol="Save" /></AppBarButton.Icon>
                                    </AppBarButton>
                                    <AppBarButton
                                        Click="DiscardConflictButton_Click"
                                        Label="{Binding Source={StaticResource Text}, Path=ActionUseRemoteVersion}"
                                        Tag="{x:Bind Id}">
                                        <AppBarButton.Icon><SymbolIcon Symbol="Download" /></AppBarButton.Icon>
                                    </AppBarButton>
                                    <AppBarButton
                                        Click="ReplaceRemoteButton_Click"
                                        Label="{Binding Source={StaticResource Text}, Path=ActionReplaceRemote}"
                                        Tag="{x:Bind Id}">
                                        <AppBarButton.Icon><SymbolIcon Symbol="Upload" /></AppBarButton.Icon>
                                    </AppBarButton>
                                </CommandBar>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </TabViewItem>

        <TabViewItem Header="{Binding Source={StaticResource Text}, Path=OperationsHealthTab}" IsClosable="False">
            <Grid Padding="0,12,0,0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                    <AppBarButton
                        Click="RefreshHealthButton_Click"
                        Label="{Binding Source={StaticResource Text}, Path=ActionRefresh}">
                        <AppBarButton.Icon><SymbolIcon Symbol="Refresh" /></AppBarButton.Icon>
                    </AppBarButton>
                    <AppBarButton
                        Click="ExportSupportButton_Click"
                        Label="{Binding Source={StaticResource Text}, Path=ActionExportSupport}">
                        <AppBarButton.Icon><SymbolIcon Symbol="Save" /></AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>
                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.HealthChecks, Mode=OneWay}" SelectionMode="None">
                    <ListView.Header>
                        <TextBlock Margin="12,0,12,8" Text="{x:Bind ViewModel.HealthSummary, Mode=OneWay}" TextWrapping="Wrap" />
                    </ListView.Header>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:HealthCheckItem">
                            <Grid Padding="12,9" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind Title}" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Detail}" TextWrapping="Wrap" />
                                <TextBlock Grid.Column="2" Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind StateText}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </TabViewItem>

        <TabViewItem Header="{Binding Source={StaticResource Text}, Path=OperationsOfflineTab}" IsClosable="False">
            <Grid Padding="0,12,0,0" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <CommandBar Background="Transparent" DefaultLabelPosition="Right">
                    <AppBarElementContainer>
                        <ComboBox
                            x:Name="OfflineRoutePicker"
                            MinWidth="220"
                            DisplayMemberPath="DisplayName"
                            ItemsSource="{x:Bind ViewModel.Routes, Mode=OneWay}"
                            PlaceholderText="{Binding Source={StaticResource Text}, Path=OfflineChooseRoute}" />
                    </AppBarElementContainer>
                    <AppBarButton
                        Click="PinOfflineButton_Click"
                        Label="{Binding Source={StaticResource Text}, Path=ActionKeepOffline}">
                        <AppBarButton.Icon><SymbolIcon Symbol="Download" /></AppBarButton.Icon>
                    </AppBarButton>
                </CommandBar>
                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.OfflineEntries, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:OfflineCacheEntry">
                            <Grid Padding="12,9" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="3">
                                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="{x:Bind DisplayPath}" />
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind StateText}" />
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="{x:Bind FreshnessText}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Text="{x:Bind SizeText}" />
                                <Button
                                    Grid.Column="2"
                                    Click="RemoveOfflineButton_Click"
                                    Content="{Binding Source={StaticResource Text}, Path=ActionFreeSpace}"
                                    Tag="{x:Bind Key}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </TabViewItem>
    </TabView>
</UserControl>
